# Configuración de Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=banco_hojas_vida

# Configuración de Ollama (Motor de IA Local)
# Asegúrate de que Ollama esté corriendo en tu máquina
# Descarga desde: https://ollama.ai

# URL base de Ollama
OLLAMA_URL=http://localhost:11434

# Modelo a usar - Opciones rápidas:
# - mistral (RECOMENDADO, ~5-10 segundos)
# - neural-chat (~5-10 segundos)
# - dolphin-mixtral (~8-15 segundos)
# - llama2 (~15-20 segundos)
# - llama3 (muy lento sin GPU, >30 segundos)
OLLAMA_MODEL=mistral

# Timeout en ms para esperar respuesta de Ollama
# Aumenta esto si tienes máquina lenta (máximo ~60000)
OLLAMA_TIMEOUT_MS=30000

# Número de reintentos si algo falla (recomendado: 2-3)
OLLAMA_RETRIES=3

# Delay entre reintentos en ms
OLLAMA_RETRY_DELAY_MS=1000

# Google Gemini AI para análisis automático de CV
# Obtén tu API key gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Puerto del servidor Express
PORT=4000
