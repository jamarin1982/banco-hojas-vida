# Configuración de Base de Datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=banco_hojas_vida

# Configuración de Ollama (Motor de IA Local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_MS=30000
OLLAMA_RETRIES=3
OLLAMA_RETRY_DELAY_MS=1000
PORT=4000

# ─── Autenticación ────────────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_en_produccion
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# ─── OAuth Google ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → APIs & Services → Credentials
# Callback: http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OAuth Microsoft ──────────────────────────────────────────────────────────
# https://portal.azure.com/ → App registrations
# Callback: http://localhost:4000/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Email SMTP ───────────────────────────────────────────────────────────────
# Sin configurar → los links de reset se imprimen en consola (modo dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

CORS_ORIGINS=http://localhost:5173
